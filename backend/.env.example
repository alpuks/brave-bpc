# Required EVE SSO application settings
ESI_APP_ID=<appid>
ESI_APP_SECRET=<secret>
ESI_APP_REDIRECT=http://localhost:2727/login

# First-run config bootstrap. These are only used when the config table is empty.
INITIAL_ALLIANCE_ID=99003214
INITIAL_ADMIN_CORP_ID=98544197
INITIAL_ADMIN_CHARACTER_ID=95154016

# Optional runtime settings
ENVIRONMENT=dev
HTTP_PORT=2727
JWT_SKEW=5m

# Optional database overrides. The docker-compose example uses the same defaults.
DB_HOST=localhost
DB_PORT=3308
DB_USER=local
DB_PASS=local
DB_NAME=local

# Optional migration control. Set to any non-empty value to run one goose down step on start.
# MIGRATE_DOWN=